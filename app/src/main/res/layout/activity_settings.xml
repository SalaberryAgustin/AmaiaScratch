<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_settings_bg">

    <!-- Decorative background shapes -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-60dp"
        android:background="@drawable/shape_circle_teal"
        android:alpha="0.35" />

    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="-20dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/shape_circle_peach"
        android:alpha="0.4" />

    <View
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/shape_circle_yellow"
        android:alpha="0.5" />

    <View
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="30dp"
        android:layout_marginTop="140dp"
        android:background="@drawable/shape_circle_lavender"
        android:alpha="0.4" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="60dp"
            android:paddingBottom="24dp">

            <!-- Titular image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/titular"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="8dp" />

            <!-- PHOTOS card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_photos"
                android:textSize="13sp"
                android:textColor="@color/color_text_muted"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvPhotoCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 fotos activas"
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnAddPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/btn_add_photos"
                    android:textColor="@color/color_primary_btn"
                    android:textStyle="bold"
                    android:background="@drawable/bg_outline_button" />
            </LinearLayout>

            <!-- ORDER card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_order"
                android:textSize="13sp"
                android:textColor="@color/color_text_muted"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/togglePhotoOrder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRandom"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/order_random"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSequential"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/order_sequential"
                        style="?attr/materialButtonOutlinedStyle" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- REVEAL TIME card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_reveal_time"
                android:textSize="13sp"
                android:textColor="@color/color_text_muted"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleRevealTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn30s"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="30s"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn60s"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="60s"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn90s"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="90s"
                        style="?attr/materialButtonOutlinedStyle" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- SURFACE card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_surface"
                android:textSize="13sp"
                android:textColor="@color/color_text_muted"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleSurface"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDirt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/surface_dirt"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSand"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/surface_sand"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrass"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/surface_grass"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSurfaceRandom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/surface_random"
                        style="?attr/materialButtonOutlinedStyle" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- MUSIC card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_music"
                android:textSize="13sp"
                android:textColor="@color/color_text_muted"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleMusic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNoMusic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/music_none"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMusic1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/music_1"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMusic2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/music_2"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMusic3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/music_3"
                        style="?attr/materialButtonOutlinedStyle" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- START button -->
            <Button
                android:id="@+id/btnStartGame"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/btn_start_game"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_primary_button"
                android:layout_marginBottom="16dp" />

            <!-- Lock hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 Pantalla bloqueada mientras jugás\nPara salir: mantené el 🔒 arriba 3 segundos"
                android:textSize="12sp"
                android:textColor="@color/color_text_muted"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
