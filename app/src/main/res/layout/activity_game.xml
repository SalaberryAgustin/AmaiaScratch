<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_game_bg">

    <!-- Photo underneath -->
    <ImageView
        android:id="@+id/ivPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scratch overlay -->
    <com.family.scratchapp.ui.game.ScratchView
        android:id="@+id/scratchView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hand hint -->
    <com.family.scratchapp.ui.game.HandHintView
        android:id="@+id/handHint"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Confetti on top of everything -->
    <com.family.scratchapp.ui.celebration.ConfettiView
        android:id="@+id/confettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Celebration banner at TOP -->
    <LinearLayout
        android:id="@+id/celebrationLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_celebration_banner"
        android:paddingVertical="16dp"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp">

        <TextView
            android:id="@+id/tvCelebrationIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌟"
            android:textSize="48sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCelebration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/celebration_message"
            android:textSize="32sp"
            android:textColor="#2C2C2C"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Lock button top-left — hold 3s to exit -->
    <FrameLayout
        android:id="@+id/btnLock"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Progress ring background -->
        <ProgressBar
            android:id="@+id/lockProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:progressDrawable="@drawable/bg_lock_progress"
            android:progress="0"
            android:max="100"
            android:visibility="visible" />

        <!-- Lock icon -->
        <ImageView
            android:id="@+id/ivLock"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lock"
            android:alpha="0.7" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
